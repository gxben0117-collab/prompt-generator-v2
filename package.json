{
  "name": "hongbing-travel-cinematic-prompt-generator",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "node scripts/prepare-vite-entry.mjs && vite build && node scripts/create_standalone_html.mjs",
    "build:vite": "vite build",
    "preview": "vite preview --host 127.0.0.1",
    "lint": "eslint .",
    "test": "vitest run",
    "sync:spec": "node scripts/sync-core-spec-module.mjs",
    "verify:ui": "node scripts/verify-ui.mjs",
    "check": "npm.cmd run sync:spec && npm.cmd run lint && npm.cmd run test && npm.cmd run build && npm.cmd run verify:ui"
  },
  "dependencies": {
    "vite": "^7.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "eslint": "^9.39.1",
    "jsdom": "^27.2.0",
    "playwright": "^1.60.0",
    "vitest": "^4.0.13"
  }
}
